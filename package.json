{
  "name": "hng-stage9-job-scheduler",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @scheduler/api dev",
    "dev:worker": "pnpm --filter @scheduler/worker dev",
    "dev:scheduler": "pnpm --filter @scheduler/scheduler dev",
    "dev:web": "pnpm --filter @scheduler/web dev",
    "build": "pnpm --filter @scheduler/core --filter @scheduler/db --filter @scheduler/handlers --filter @scheduler/api --filter @scheduler/worker --filter @scheduler/scheduler --filter @scheduler/web build",
    "docker:up": "docker compose up -d --wait",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "docker:wait": "docker compose exec postgres pg_isready -U scheduler -d job_scheduler",
    "db:generate": "pnpm --filter @scheduler/db generate",
    "db:migrate": "pnpm --filter @scheduler/db migrate",
    "db:seed": "pnpm --filter @scheduler/db seed",
    "benchmark": "pnpm --filter @scheduler/core benchmark",
    "test:handlers": "pnpm --filter @scheduler/handlers test",
    "test:integration": "tsx scripts/integration-test.ts",
    "lint": "eslint ."
  },
  "engines": {
    "node": ">=20.0.0 <21.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.0",
    "eslint": "^9.15.0",
    "tsx": "^4.19.0",
    "typescript-eslint": "^8.15.0"
  }
}
