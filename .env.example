# Database — PostgreSQL connection string (required)
DATABASE_URL=postgresql://scheduler:scheduler@localhost:5432/job_scheduler

# Redis — locks + SSE pub/sub only (required)
REDIS_URL=redis://localhost:6379

# API server
API_PORT=3200
API_HOST=0.0.0.0

# DLQ alert — fires once per threshold crossing (see ARCHITECTURE.md)
ADMIN_EMAIL=admin@dilamme.com
DLQ_ALERT_EMAIL=admin@dilamme.com
DLQ_THRESHOLD=10

# Worker
WORKER_POLL_INTERVAL_MS=500
WORKER_POLL_MS=500
WORKER_LOCK_TTL_SECONDS=300

# Scheduler
SCHEDULER_TICK_INTERVAL_MS=500
SCHEDULER_TICK_MS=500
AGING_INTERVAL_SECONDS=30

# Logging — use Pino structured logs in production (never console.log)
LOG_LEVEL=info
